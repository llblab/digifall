{
  "name": "digifall",
  "version": "0.14.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*"
  ],
  "overrides": {
    "stylelint-config-idiomatic-order": {
      "stylelint-order": "8.1.1"
    }
  },
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "relay": "node nodes/relay/index.js",
    "leaderboard": "node nodes/leaderboard/index.js",
    "test": "npm test --workspaces",
    "check": "svelte-check --tsconfig ./jsconfig.json",
    "lint": "stylelint 'src/**/*.{css,svelte}' '*.html' 'public/**/*.html' --fix",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "6.2.4",
    "autoprefixer": "10.5.0",
    "postcss": "8.5.12",
    "postcss-nested": "7.0.2",
    "prettier": "3.8.3",
    "prettier-plugin-svelte": "3.5.1",
    "stylelint": "17.9.1",
    "stylelint-config-css-modules": "4.6.0",
    "stylelint-config-html": "1.1.0",
    "stylelint-config-idiomatic-order": "10.0.0",
    "stylelint-config-standard": "40.0.0",
    "svelte": "5.55.5",
    "svelte-check": "4.4.6",
    "vite": "7.3.2",
    "vite-plugin-pwa": "1.2.0"
  },
  "dependencies": {
    "@chainsafe/libp2p-gossipsub": "14.1.2",
    "@chainsafe/libp2p-yamux": "8.0.1",
    "@libp2p/bootstrap": "12.0.19",
    "@libp2p/circuit-relay-v2": "4.2.3",
    "@libp2p/config": "1.1.30",
    "@libp2p/floodsub": "11.0.19",
    "@libp2p/identify": "4.1.3",
    "@libp2p/interface": "3.2.2",
    "@libp2p/keychain": "6.1.0",
    "@libp2p/plaintext": "3.0.18",
    "@libp2p/pubsub-peer-discovery": "12.0.0",
    "@libp2p/websockets": "10.1.11",
    "@multiformats/multiaddr": "13.0.1",
    "datastore-fs": "11.0.4",
    "datastore-idb": "4.0.3",
    "howler": "2.2.4",
    "libp2p": "3.2.3",
    "uint8arrays": "5.1.1"
  }
}
